# ──────────────────────────────────────────────
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# ──────────────────────────────────────────────

# Flask secret key – used to sign session cookies.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change_me_to_a_long_random_string

# ──────────────────────────────────────────────
# AWS Bedrock Knowledge Base (required)
# ──────────────────────────────────────────────
# IDs of the existing Bedrock Knowledge Base and its S3 data source.
BEDROCK_KNOWLEDGE_BASE_ID=your_knowledge_base_id
BEDROCK_DATA_SOURCE_ID=your_data_source_id

# Foundation model used by RetrieveAndGenerate (optional; default shown).
# BEDROCK_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0

# Full model ARN (optional). If unset, it is built from AWS_REGION +
# BEDROCK_MODEL_ID as arn:aws:bedrock:<region>::foundation-model/<model-id>.
# BEDROCK_MODEL_ARN=

# ──────────────────────────────────────────────
# AWS / S3 (documents are uploaded here; the KB ingests from this prefix)
# ──────────────────────────────────────────────
# AWS_REGION=us-east-1
# S3_BUCKET=oz-private-aviadt
# Key prefix under which documents are stored (must match the KB data source).
# S3_PREFIX=data/

# NOTE: AWS credentials are NOT read from this file. boto3 uses the default
# AWS credential chain (e.g. `aws configure`, environment variables, or an
# EC2 instance role). Make sure `aws s3 ls s3://oz-private-aviadt` works.

# ──────────────────────────────────────────────
# Uploads
# ──────────────────────────────────────────────
# Maximum size of a single upload request, in megabytes.
# MAX_UPLOAD_MB=20

# Comma-separated list of allowed upload file extensions (no dots).
# ALLOWED_UPLOAD_EXTENSIONS=txt,pdf,docx

# ──────────────────────────────────────────────
# Database / Flask
# ──────────────────────────────────────────────
# SQLite database file path
# DB_PATH=database/chat_history.db

# Flask host / port
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5000
# FLASK_DEBUG=false
